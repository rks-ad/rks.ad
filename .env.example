# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Oracle Database Configuration
# For Oracle Thin Mode (serverless compatible)
ORACLE_USER=your_oracle_username
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECT_STRING=your_oracle_connect_string

# Example Oracle Connect Strings:
# For Oracle Cloud (Always Free):
# ORACLE_CONNECT_STRING=your_adb_domain_name_high

# For Local Oracle Database:
# ORACLE_CONNECT_STRING=localhost:1521/ORCL

# For Oracle with Thin Mode (recommended for Vercel):
# ORACLE_CONNECT_STRING=your_host:1521/your_service_name

# Node Environment
NODE_ENV=production
